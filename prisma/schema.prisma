generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 사용자 (인증)
// ============================================================
model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  displayName   String    @map("display_name") @db.VarChar(100)
  role          String    @default("admin") @db.VarChar(20)
  isActive      Boolean   @default(true) @map("is_active")
  failedAttempts Int      @default(0) @map("failed_attempts")
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  auditLogs     AuditLog[]

  @@map("tb_user")
}

// ============================================================
// 장비 대장
// ============================================================
model Device {
  id              Int       @id @default(autoincrement())
  productName     String    @map("product_name") @db.VarChar(100)
  modelName       String    @map("model_name") @db.VarChar(100)
  lotNumber       String?   @map("lot_number") @db.VarChar(50)
  serialNumber    String    @unique @map("serial_number") @db.VarChar(50)
  deviceId        String    @unique @map("device_id") @db.VarChar(50)
  status          String    @db.VarChar(20) // "판매완료", "보관", "수리중", "폐기"
  customerName    String?   @map("customer_name") @db.VarChar(200)
  customerCountry String?   @map("customer_country") @db.VarChar(50)
  installLocation String?   @map("install_location") @db.VarChar(200)

  // 현재 버전 정보
  currentSwVersion  String? @map("current_sw_version") @db.VarChar(50)
  currentAiVersion  String? @map("current_ai_version") @db.VarChar(50)
  currentPlcVersion String? @map("current_plc_version") @db.VarChar(50)

  // 유지보수 정보
  lastDeployDate      DateTime? @map("last_deploy_date")
  lastMaintenanceDate DateTime? @map("last_maintenance_date")
  nextCalibrationDue  DateTime? @map("next_calibration_due")
  sourceOnCount       Int       @default(0) @map("source_on_count")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deployHistory    DeployHistory[]
  configSnapshots  ConfigSnapshot[]
  maintenanceLogs  MaintenanceLog[]

  @@map("tb_device")
}

// ============================================================
// 배포 이력
// ============================================================
model DeployHistory {
  id          Int      @id @default(autoincrement())
  deviceId    Int      @map("device_id")
  device      Device   @relation(fields: [deviceId], references: [id])

  // 배포 버전
  swVersion   String?  @map("sw_version") @db.VarChar(50)
  aiVersion   String?  @map("ai_version") @db.VarChar(50)
  plcVersion  String?  @map("plc_version") @db.VarChar(50)

  // 배포 정보
  deployDate      DateTime @map("deploy_date")
  deployer        String?  @db.VarChar(100)
  receiver        String?  @db.VarChar(100)
  deployType      String?  @map("deploy_type") @db.VarChar(50) // "신규설치", "업데이트", "유지보수", "긴급패치"
  installLocation String?  @map("install_location") @db.VarChar(200) // 배포 시점 설치처 (장비이전 시 device.installLocation과 다를 수 있음)
  description     String?

  // Config 스냅샷 (Phase B 연동)
  configSnapshot String? @map("config_snapshot")

  // 릴리스 레지스트리 연결 (Phase B1)
  swReleaseId  Int?     @map("sw_release_id")
  aiReleaseId  Int?     @map("ai_release_id")
  plcReleaseId Int?     @map("plc_release_id")
  swRelease    Release? @relation("SwRelease", fields: [swReleaseId], references: [id])
  aiRelease    Release? @relation("AiRelease", fields: [aiReleaseId], references: [id])
  plcRelease   Release? @relation("PlcRelease", fields: [plcReleaseId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")

  @@map("tb_deploy_history")
}

// ============================================================
// 릴리스 레지스트리 (Phase B1)
// SW/AI/PLC 빌드 산출물 카탈로그 — "이 버전이 정확히 어떤 빌드인지" 추적
// ============================================================
model Release {
  id             Int       @id @default(autoincrement())
  component      String    @db.VarChar(20)  // "SW" | "AI" | "PLC"
  version        String    @db.VarChar(50)  // "2.0.0.0"
  modelName      String?   @map("model_name") @db.VarChar(100) // null = 공통, 값 있으면 특정 모델 전용

  buildDate      DateTime? @map("build_date")
  builder        String?   @db.VarChar(100)
  artifactName   String?   @map("artifact_name") @db.VarChar(255)   // "AIXAC.RX.SW.DA-2.0.0.0.zip"
  artifactPath   String?   @map("artifact_path") @db.VarChar(500)   // 사내 파일서버 경로 또는 URL
  artifactSha256 String?   @map("artifact_sha256") @db.VarChar(64)  // 무결성 검증용 (선택)

  changelog      String?   // 마크다운 한글 변경요약
  releaseType    String?   @map("release_type") @db.VarChar(20)     // "정식" | "베타" | "긴급패치"
  isDeprecated   Boolean   @default(false) @map("is_deprecated")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  swDeploys      DeployHistory[] @relation("SwRelease")
  aiDeploys      DeployHistory[] @relation("AiRelease")
  plcDeploys     DeployHistory[] @relation("PlcRelease")

  @@unique([component, version, modelName])
  @@map("tb_release")
}

// ============================================================
// Config 스냅샷 (Phase B — 테이블만 생성)
// ============================================================
model ConfigSnapshot {
  id            Int      @id @default(autoincrement())
  deviceId      Int      @map("device_id")
  device        Device   @relation(fields: [deviceId], references: [id])
  configVersion Int?     @map("config_version")
  swVersion     String?  @map("sw_version") @db.VarChar(50)
  snapshotJson  String   @map("snapshot_json")
  triggerType   String?  @map("trigger_type") @db.VarChar(50)
  source        String?  @db.VarChar(50)
  capturedAt    DateTime @map("captured_at")
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  @@map("tb_config_snapshot")
}

// ============================================================
// 유지보수 이력 (Phase B — 테이블만 생성)
// ============================================================
model MaintenanceLog {
  id              Int       @id @default(autoincrement())
  deviceId        Int       @map("device_id")
  device          Device    @relation(fields: [deviceId], references: [id])
  maintenanceType String    @map("maintenance_type") @db.VarChar(50)  // "캘리브레이션" | "소스교체" | "검출기교체" | "SW업데이트" | "점검" | "기타"
  status          String    @default("완료") @db.VarChar(20)            // "예정" | "진행중" | "완료" | "취소"
  performedBy     String?   @map("performed_by") @db.VarChar(100)
  performedAt     DateTime  @map("performed_at")
  description     String?
  cost            Int?                                                  // 부품비/외주비 (원 단위, 선택)
  attachments     Json?                                                 // [{name, path}] — 사진/리포트 파일 경로(W1과 동일하게 경로만)
  nextDueDate     DateTime? @map("next_due_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([deviceId])
  @@index([performedAt])
  @@map("tb_maintenance_log")
}

// ============================================================
// 감사 로그
// ============================================================
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String   @db.VarChar(20) // "CREATE", "UPDATE", "DELETE"
  tableName String   @map("table_name") @db.VarChar(50)
  recordId  Int      @map("record_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tb_audit_log")
}
